# MCP WebSocket Hub Configuration

# HTTP/WS listen port
HUB_PORT=8000

# Path to persist device credentials (bcrypt hashes)
HUB_CREDENTIALS_FILE=./data/devices.json

# API key to protect device registration endpoint.
# If empty, registration is open (development mode).
# Checked via X-API-Key header or Authorization: Bearer <key>.
HUB_REGISTER_API_KEY=

# Comma-separated list of allowed CORS and WebSocket origins.
# If empty, all origins are allowed (development mode).
# Example: https://app.datumbridge.io,https://admin.datumbridge.io
HUB_ALLOWED_ORIGINS=

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# How long a pairing code stays valid (Go duration: 1m, 5m, 10m, 1h). Default 1m.
# After expiry the code is removed; the device must call register again for a new code.
HUB_PAIRING_TTL=1m

# Strip leading /api/ws-hub from incoming paths (DatumBridge Studio public URL). Default: on.
# Set to 0 / false / no only if your proxy always forwards paths without that prefix.
# HUB_HTTP_STRIP_PREFIX=0

# --- Optional: sync embedded edge tool catalog to DatumBridge Tool Registry (datumbridge-mcp) ---
# When set, hub POSTs each catalog entry to POST {TOOL_REGISTRY_BASE_URL}/tools on startup (retries).
# Must include /api/v1 (e.g. http://datumbridge-mcp:8081/api/v1).
# TOOL_REGISTRY_BASE_URL=http://datumbridge-mcp:8081/api/v1
# Same key as MCP_API_KEY / MCP_SERVICE_API_KEY when registry auth is enabled.
# TOOL_REGISTRY_API_KEY=
# Value stored on each tool as mcpServer (execution routing / grouping in Studio).
# WS_HUB_REGISTRY_MCPSERVER_NAME=datumbridge_mcp_ws_hub
